{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "action_catalog.v1",
  "title": "Action Catalog v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "catalog_version",
    "actions"
  ],
  "properties": {
    "schema_version": {
      "const": "action_catalog.v1"
    },
    "catalog_version": {
      "type": "string",
      "minLength": 1
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/actionSpec"
      }
    }
  },
  "$defs": {
    "parameterDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "type",
        "required"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "string",
            "number",
            "integer",
            "boolean",
            "object",
            "array"
          ]
        },
        "required": {
          "type": "boolean"
        },
        "unit": {
          "type": "string",
          "minLength": 1
        },
        "minimum": {
          "type": "number"
        },
        "maximum": {
          "type": "number"
        },
        "min_length": {
          "type": "integer",
          "minimum": 0
        },
        "max_length": {
          "type": "integer",
          "minimum": 1
        },
        "min_items": {
          "type": "integer",
          "minimum": 0
        },
        "enum": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": ["string", "number", "integer", "boolean"]
          }
        }
      }
    },
    "actionSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action",
        "command",
        "description",
        "phase",
        "prerequisites",
        "incompatible_with",
        "parameter_definitions"
      ],
      "properties": {
        "action": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 10
        },
        "phase": {
          "type": "string",
          "enum": [
            "setup",
            "materials",
            "geometry",
            "simulation",
            "exports"
          ]
        },
        "prerequisites": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "incompatible_with": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "parameter_definitions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/parameterDefinition"
          }
        }
      }
    }
  }
}