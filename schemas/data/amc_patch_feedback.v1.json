{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "amc_patch_feedback.v1",
  "title": "AMC Patch Feedback v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "timestamp_utc",
    "antenna_family",
    "patch_shape",
    "feed_type",
    "polarization",
    "substrate_name",
    "substrate_epsilon_r",
    "substrate_loss_tangent",
    "substrate_height_mm",
    "conductor_name",
    "conductor_conductivity_s_per_m",
    "target_frequency_ghz",
    "target_bandwidth_mhz",
    "target_minimum_gain_dbi",
    "target_maximum_vswr",
    "target_minimum_return_loss_db",
    "amc_unit_cell_period_mm",
    "amc_patch_size_mm",
    "amc_gap_mm",
    "amc_via_radius_mm",
    "amc_via_height_mm",
    "amc_ground_size_mm",
    "amc_array_rows",
    "amc_array_cols",
    "amc_air_gap_mm",
    "actual_reflection_phase_center_ghz",
    "actual_reflection_phase_bandwidth_mhz",
    "actual_gain_improvement_dbi",
    "actual_back_lobe_reduction_db",
    "actual_center_frequency_ghz",
    "actual_bandwidth_mhz",
    "actual_return_loss_db",
    "actual_vswr",
    "actual_gain_dbi",
    "actual_radiation_efficiency_pct",
    "actual_total_efficiency_pct",
    "actual_directivity_dbi",
    "accepted",
    "solver_status",
    "simulation_time_sec",
    "notes"
  ],
  "properties": {
    "run_id": {"type": "string"},
    "timestamp_utc": {"type": "string"},
    "antenna_family": {"const": "amc_patch"},
    "patch_shape": {"type": "string"},
    "feed_type": {"type": "string"},
    "polarization": {"type": "string"},
    "substrate_name": {"type": "string"},
    "substrate_epsilon_r": {"type": "number"},
    "substrate_loss_tangent": {"type": "number"},
    "substrate_height_mm": {"type": "number"},
    "conductor_name": {"type": "string"},
    "conductor_conductivity_s_per_m": {"type": "number"},
    "target_frequency_ghz": {"type": "number"},
    "target_bandwidth_mhz": {"type": "number"},
    "target_minimum_gain_dbi": {"type": "number"},
    "target_maximum_vswr": {"type": "number"},
    "target_minimum_return_loss_db": {"type": "number"},
    "amc_unit_cell_period_mm": {"type": "number"},
    "amc_patch_size_mm": {"type": "number"},
    "amc_gap_mm": {"type": "number"},
    "amc_via_radius_mm": {"type": "number"},
    "amc_via_height_mm": {"type": "number"},
    "amc_ground_size_mm": {"type": "number"},
    "amc_array_rows": {"type": "integer"},
    "amc_array_cols": {"type": "integer"},
    "amc_air_gap_mm": {"type": "number"},
    "actual_reflection_phase_center_ghz": {"type": "number"},
    "actual_reflection_phase_bandwidth_mhz": {"type": "number"},
    "actual_gain_improvement_dbi": {"type": "number"},
    "actual_back_lobe_reduction_db": {"type": "number"},
    "actual_center_frequency_ghz": {"type": "number"},
    "actual_bandwidth_mhz": {"type": "number"},
    "actual_return_loss_db": {"type": "number"},
    "actual_vswr": {"type": "number"},
    "actual_gain_dbi": {"type": "number"},
    "actual_radiation_efficiency_pct": {"type": "number"},
    "actual_total_efficiency_pct": {"type": "number"},
    "actual_directivity_dbi": {"type": "number"},
    "accepted": {"type": "boolean"},
    "solver_status": {"type": "string"},
    "simulation_time_sec": {"type": "number"},
    "notes": {"type": "string"}
  }
}