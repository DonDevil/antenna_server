{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "rect_patch_feedback.v1",
  "title": "Rectangular Patch Feedback v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "timestamp_utc",
    "antenna_family",
    "patch_shape",
    "feed_type",
    "polarization",
    "substrate_name",
    "conductor_name",
    "target_frequency_ghz",
    "target_bandwidth_mhz",
    "target_minimum_gain_dbi",
    "target_maximum_vswr",
    "target_minimum_return_loss_db",
    "substrate_epsilon_r",
    "substrate_height_mm",
    "patch_length_mm",
    "patch_width_mm",
    "patch_height_mm",
    "substrate_length_mm",
    "substrate_width_mm",
    "feed_length_mm",
    "feed_width_mm",
    "feed_offset_x_mm",
    "feed_offset_y_mm",
    "actual_center_frequency_ghz",
    "actual_bandwidth_mhz",
    "actual_return_loss_db",
    "actual_vswr",
    "actual_gain_dbi",
    "actual_radiation_efficiency_pct",
    "actual_total_efficiency_pct",
    "actual_directivity_dbi",
    "actual_peak_theta_deg",
    "actual_peak_phi_deg",
    "actual_front_to_back_db",
    "actual_axial_ratio_db",
    "accepted",
    "solver_status",
    "simulation_time_sec",
    "notes",
    "farfield_artifact_path",
    "s11_artifact_path"
  ],
  "properties": {
    "run_id": {"type": "string", "minLength": 1},
    "timestamp_utc": {"type": "string", "minLength": 1},
    "antenna_family": {"const": "microstrip_patch"},
    "patch_shape": {"const": "rectangular"},
    "feed_type": {"const": "edge"},
    "polarization": {"type": "string"},
    "substrate_name": {"type": "string", "minLength": 1},
    "conductor_name": {"type": "string", "minLength": 1},
    "target_frequency_ghz": {"type": "number", "minimum": 2.0, "maximum": 7.0},
    "target_bandwidth_mhz": {"type": "number", "minimum": 30.0, "maximum": 300.0},
    "target_minimum_gain_dbi": {"type": "number"},
    "target_maximum_vswr": {"type": "number", "minimum": 1.0},
    "target_minimum_return_loss_db": {"type": "number"},
    "substrate_epsilon_r": {"type": "number", "minimum": 2.2, "maximum": 4.4},
    "substrate_height_mm": {"type": "number", "minimum": 0.8, "maximum": 3.2},
    "patch_length_mm": {"type": "number", "minimum": 5.0, "maximum": 80.0},
    "patch_width_mm": {"type": "number", "minimum": 5.0, "maximum": 100.0},
    "patch_height_mm": {"type": "number", "minimum": 0.01, "maximum": 3.0},
    "substrate_length_mm": {"type": "number", "minimum": 10.0, "maximum": 200.0},
    "substrate_width_mm": {"type": "number", "minimum": 10.0, "maximum": 200.0},
    "feed_length_mm": {"type": "number", "minimum": 1.0, "maximum": 100.0},
    "feed_width_mm": {"type": "number", "minimum": 0.2, "maximum": 8.0},
    "feed_offset_x_mm": {"type": "number", "minimum": -80.0, "maximum": 80.0},
    "feed_offset_y_mm": {"type": "number", "minimum": -50.0, "maximum": 0.0},
    "actual_center_frequency_ghz": {"type": "number", "exclusiveMinimum": 0.0},
    "actual_bandwidth_mhz": {"type": "number", "minimum": 0.0},
    "actual_return_loss_db": {"type": "number"},
    "actual_vswr": {"type": "number", "minimum": 1.0},
    "actual_gain_dbi": {"type": "number"},
    "actual_radiation_efficiency_pct": {"type": "number", "minimum": 0.0, "maximum": 100.0},
    "actual_total_efficiency_pct": {"type": "number", "minimum": 0.0, "maximum": 100.0},
    "actual_directivity_dbi": {"type": "number"},
    "actual_peak_theta_deg": {"type": "number", "minimum": 0.0, "maximum": 360.0},
    "actual_peak_phi_deg": {"type": "number", "minimum": 0.0, "maximum": 360.0},
    "actual_front_to_back_db": {"type": "number"},
    "actual_axial_ratio_db": {"type": "number", "minimum": 0.0},
    "accepted": {"type": "boolean"},
    "solver_status": {"type": "string", "minLength": 1},
    "simulation_time_sec": {"type": "number", "minimum": 0.0},
    "notes": {"type": "string"},
    "farfield_artifact_path": {"type": "string"},
    "s11_artifact_path": {"type": "string"}
  }
}